# Database (MySQL via Prisma)
DATABASE_URL="mysql://user:password@localhost:3306/nh_media"

# JWT auth
JWT_SECRET=
JWT_EXPIRES_IN=7d
# ALLOW_OPEN_REGISTRATION=true  # only for first-time bootstrap

# Google OAuth (Gmail connect)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=
# Optional — Gmail Pub/Sub topic for real-time webhook push.
# projects/<your-gcp-project>/topics/<topic-name>
VITE_GMAIL_PUBSUB_TOPIC=

# Microsoft OAuth / MSAL (Outlook connect — optional)
MSAL_CLIENT_ID=
VITE_MSAL_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Fulfillment partner APIs (optional)
PRINTWAY_ACCESS_TOKEN=
MERCHIZE_ACCESS_TOKEN=

# Webhook / cron security
CRON_SECRET=
CRON_SECRET2=
WEBHOOK_SECRET_TOKEN=
